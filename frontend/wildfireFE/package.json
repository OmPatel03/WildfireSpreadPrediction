{
  "name": "wildfirefe",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "preview:perf": "vite preview --host 127.0.0.1 --port 4173",
    "perf:lighthouse:local": "npm run build && start-server-and-test \"npm run preview:perf\" http://127.0.0.1:4173 \"node scripts/run-lighthouse.mjs http://127.0.0.1:4173 local\"",
    "perf:lighthouse:live": "node scripts/run-lighthouse.mjs https://wisprlabs.com live",
    "perf:lighthouse": "npm run perf:lighthouse:local && npm run perf:lighthouse:live"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "mapbox-gl": "^3.16.0",
    "maplibre-gl": "^5.11.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "jsdom": "^29.0.1",
    "lighthouse": "^12.8.2",
    "start-server-and-test": "^2.1.2",
    "vite": "^7.1.7",
    "vitest": "^4.1.2"
  }
}
